# NEXTAUTH所需的SECRET，可使用openssl生成
AUTH_SECRET="$(openssl rand -base64 32)"
# SYSCALL CURL通讯使用的SECRET，可使用openssl生成
SYSCALL_SECRET="$(openssl rand -base64 32)"

# OAuth2配置
AUTH_URL="https://auth.heerkirov.com"
AUTH_CLIENT_ID="reel-hub"
AUTH_CLIENT_SECRET="..."

# 应用URL，用于NEXTAUTH的回调
NEXTAUTH_URL="http://localhost:3000"

# 数据的URL，用于Prisma的连接
DATABASE_URL="postgresql://user:pass@host:5432/reel_hub?schema=public"

# OSS配置信息
OSS_ACCESS_KEY_ID=AccessKeyId
OSS_ACCESS_KEY_SECRET=AccessKeySecret
OSS_BUCKET=BucketName
OSS_REGION=oss-cn-shanghai
OSS_INTERNAL=false
OSS_SECURE=true
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_BASE_PATH=