// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum ProjectType {
  ANIME
  GAME
  MOVIE
  NOVEL
  MANGA
}

enum OriginalType {
  ORIGINAL
  GAME
  NOVEL
  MANGA
  OTHER
}

enum BoardcastType {
  TV_AND_WEB
  OVA_AND_OAD
  MOVIE
  OTHER
}

enum OnlineType {
  SINGLE_PLAYER
  MULTI_PLAYER
  ONLINE_GAME
}

enum RecordStatus {
  WATCHING // 进行中
  COMPLETED // 已结束
  ON_HOLD // 暂停
  DROPPED // 弃坑
}

enum FollowType {
  //追番
  FOLLOW
  //补番,
  CATCH_UP
  //重看
  REWATCH
}

enum ShoppingType {
  //本体
  MAIN
  //DLC
  DLC
  //内购
  IN_APP_PURCHASE
  //订阅
  SUBSCRIPTION
  //其他
  OTHER
}

model Project {
  id                 String   @id @default(nanoid())
  title              String   @db.VarChar(256)
  subtitles          String   @db.Text
  description        String   @db.Text
  keywords           String   @db.Text
  type               ProjectType
  publishTime        String?   @db.VarChar(10)
  ratingS            Int?
  ratingV            Int?
  region             String?
  relations          Json
  relationsTopology  Json
  resources          Json
  createTime         DateTime @db.Timestamptz(3)
  updateTime         DateTime @db.Timestamptz(3)
  creator            String   @db.VarChar(24)
  updator            String   @db.VarChar(24)

  // Anime specific fields
  originalType             OriginalType?
  boardcastType            BoardcastType?
  episodeDuration          Int?
  episodeTotalNum          Int?
  episodePublishedNum      Int?
  episodePublishedRecords  Json?
  episodePublishPlan       Json?

  // Game specific fields
  platform    String[] @db.VarChar(64)
  onlineType  OnlineType?

  // Relations
  staffs            ProjectStaffRelation[]
  tags              ProjectTagRelation[]
  purchaseSummaries PurchaseSummary[]
  purchases         Purchase[]
  records           Record[]
  comments          Comment[]
  recordProgresses  RecordProgress[]

  @@index([type, publishTime])
}

model Staff {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(256) @unique
  otherNames  String   @db.VarChar(256)
  description String   @db.Text
  createTime  DateTime @db.Timestamptz(3)
  updateTime  DateTime @db.Timestamptz(3)
  creator     String   @db.VarChar(24)
  updator     String   @db.VarChar(24)

  projects ProjectStaffRelation[]
}

model ProjectStaffRelation {
  projectId String
  staffId   Int
  staffType String @db.VarChar(256)

  project Project @relation(fields: [projectId], references: [id])
  staff   Staff   @relation(fields: [staffId], references: [id])

  @@id([projectId, staffId, staffType])
  @@index([staffType, projectId])
}

model Tag {
  id          Int      @id @default(autoincrement())
  type        ProjectType
  name        String   @db.VarChar(256)
  description String   @db.Text
  createTime  DateTime @db.Timestamptz(3)
  updateTime  DateTime @db.Timestamptz(3)
  creator     String   @db.VarChar(24)
  updator     String   @db.VarChar(24)

  projects ProjectTagRelation[]

  @@unique([type, name])
}

model ProjectTagRelation {
  projectId String
  tagId     Int

  project Project @relation(fields: [projectId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([projectId, tagId])
}

model PurchaseSummary {
  id          Int @id @default(autoincrement())
  ownerId     String @db.VarChar(24)
  projectId   String
  totalCost   Decimal @db.Decimal(10, 2)
  totalCount  Int
  createTime  DateTime @db.Timestamptz(3)
  updateTime  DateTime @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id])

  @@unique([ownerId, projectId])
}

model Purchase {
  id           String   @id @default(nanoid())
  ownerId      String   @db.VarChar(24)
  projectId    String
  purchaseType ShoppingType
  description  String   @db.Text
  cost         Decimal  @db.Decimal(10, 2)
  purchaseTime DateTime @db.Timestamptz(3)
  createTime   DateTime @db.Timestamptz(3)
  updateTime   DateTime @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id])

  @@index([ownerId, projectId, purchaseTime])
}

model Record {
  id          Int       @id @default(autoincrement())
  ownerId     String    @db.VarChar(24)
  projectId   String
  specialAttention Boolean
  status      RecordStatus
  progressCount Int
  startTime   DateTime? @db.Timestamptz(3)
  endTime     DateTime? @db.Timestamptz(3)
  lastActivityTime DateTime? @db.Timestamptz(3)
  lastActivityEvent Json @default("{}")
  createTime DateTime @db.Timestamptz(3)
  updateTime DateTime @db.Timestamptz(3)

  project    Project          @relation(fields: [projectId], references: [id])
  progresses RecordProgress[]

  @@unique([ownerId, projectId])
}

model RecordProgress {
  id         Int       @id @default(autoincrement())
  projectId  String
  recordId   Int
  ordinal    Int
  isLatest   Boolean   @default(false)
  status     RecordStatus
  startTime  DateTime? @db.Timestamptz(3)
  endTime    DateTime? @db.Timestamptz(3)
  createTime DateTime @db.Timestamptz(3)
  updateTime DateTime @db.Timestamptz(3)

  // Anime specific fields
  episodeWatchedNum     Int?
  episodeWatchedRecords Json?
  followType             FollowType?

  // Game specific fields
  platform String[] @db.VarChar(64)

  project Project @relation(fields: [projectId], references: [id])
  record  Record  @relation(fields: [recordId], references: [id])
}

model Comment {
  id              Int      @id @default(autoincrement())
  ownerId         String   @db.VarChar(24)
  projectId       String
  score           Int?
  title           String?  @db.Text
  article         String?  @db.Text
  createTime      DateTime @db.Timestamptz(3)
  updateTime      DateTime @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id])

  @@unique([ownerId, projectId])
}

model Statistic {
  id          Int      @id @default(autoincrement())
  ownerId     String   @db.VarChar(24)
  type        String   @db.VarChar(256)
  key         String?  @db.VarChar(256)
  content     Json
  createTime  DateTime @db.Timestamptz(3)
  updateTime  DateTime @db.Timestamptz(3)

  @@unique([ownerId, type, key])
}

model UserPreference {
  userId         String   @id @db.VarChar(24)
  timezone       String?  @db.VarChar(64)
  autoTimezone   Boolean  @default(true)
  nightTimeTable Boolean  @default(true)
  currency       String   @default("CNY") @db.VarChar(8)
}
